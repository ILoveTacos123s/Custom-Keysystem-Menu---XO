local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UIS          = game:GetService("UserInputService")
local LP           = Players.LocalPlayer

-- Theme
local T = {
    BG        = Color3.fromRGB(8, 8, 10),
    Panel     = Color3.fromRGB(16, 16, 20),
    PanelHdr  = Color3.fromRGB(20, 20, 26),
    Item      = Color3.fromRGB(18, 18, 24),
    ItemHov   = Color3.fromRGB(28, 28, 36),
    ItemAct   = Color3.fromRGB(33, 33, 42),
    Border    = Color3.fromRGB(40, 40, 52),
    Text      = Color3.fromRGB(235, 235, 245),
    Dim       = Color3.fromRGB(140, 140, 160),
    Muted     = Color3.fromRGB(75, 75, 90),
    SliderBg  = Color3.fromRGB(30, 30, 38),
    TogOff    = Color3.fromRGB(42, 42, 54),
    White     = Color3.fromRGB(255, 255, 255),
    Black     = Color3.fromRGB(0, 0, 0),
    Shadow    = Color3.fromRGB(0, 0, 0),
}

local PANEL_W = 260
local HDR_H   = 36
local ITEM_H  = 30
local PAD     = 12
local GAP     = 20
local FONT    = Enum.Font.GothamSemibold
local FONTR   = Enum.Font.Gotham
local RAD     = UDim.new(0, 6)

-- Helper functions (shortened)
local function mkCorner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = r or RAD
    c.Parent = parent
end

local function mkStroke(parent, col, thick)
    local s = Instance.new("UIStroke")
    s.Color = col or T.Border
    s.Thickness = thick or 1
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = parent
end

local function mkFrame(parent, bg, pos, size, clip)
    local f = Instance.new("Frame")
    f.BackgroundColor3 = bg or T.Panel
    f.BackgroundTransparency = 0
    f.BorderSizePixel = 0
    f.Position = pos or UDim2.new(0,0,0,0)
    f.Size = size or UDim2.new(1,0,0,30)
    if clip ~= nil then f.ClipsDescendants = clip end
    f.Parent = parent
    return f
end

local function mkLabel(parent, text, pos, size, col, ts, font, xa)
    local l = Instance.new("TextLabel")
    l.BackgroundTransparency = 1
    l.BorderSizePixel = 0
    l.Position = pos or UDim2.new(0,0,0,0)
    l.Size = size or UDim2.new(1,0,1,0)
    l.Text = text or ""
    l.TextColor3 = col or T.Text
    l.TextSize = ts or 12
    l.Font = font or FONTR
    l.TextXAlignment = xa or Enum.TextXAlignment.Left
    l.TextYAlignment = Enum.TextYAlignment.Center
    l.Parent = parent
    return l
end

local function mkBtn(parent, pos, size, bg)
    local b = Instance.new("TextButton")
    b.BackgroundColor3 = bg or T.Item
    b.BackgroundTransparency = 0
    b.BorderSizePixel = 0
    b.Position = pos or UDim2.new(0,0,0,0)
    b.Size = size or UDim2.new(1,0,0,ITEM_H)
    b.Text = ""
    b.AutoButtonColor = false
    b.Parent = parent
    return b
end

local function hover(b, on, off)
    on = on or T.ItemHov; off = off or T.Item
    b.MouseEnter:Connect(function() b.BackgroundColor3 = on end)
    b.MouseLeave:Connect(function() b.BackgroundColor3 = off end)
end

local function addDropShadow(frame)
    local shadow = Instance.new("Frame")
    shadow.BackgroundColor3 = T.Shadow
    shadow.BackgroundTransparency = 0.6
    shadow.BorderSizePixel = 0
    shadow.Size = UDim2.new(1, 8, 1, 8)
    shadow.Position = UDim2.new(0, 4, 0, 4)
    shadow.ZIndex = -1
    mkCorner(shadow, RAD)
    shadow.Parent = frame
end

-- Dragging
local function makeDraggable(frame, header)
    local dragging = false
    local dragStart, startPos
    local threshold = 5

    header.MouseButton1Down:Connect(function()
        dragging = true
        dragStart = UIS:GetMouseLocation()
        startPos = frame.Position
    end)

    UIS.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = UIS:GetMouseLocation() - dragStart
            if math.abs(delta.X) > threshold or math.abs(delta.Y) > threshold then
                frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X,
                                           startPos.Y.Scale, startPos.Y.Offset + delta.Y)
            end
        end
    end)

    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
end

-- Main UI class
local UI = {}
UI.__index = UI

function UI.new(cfg)
    cfg = cfg or {}
    local self = setmetatable({}, UI)
    self.Accent   = cfg.Accent or Color3.fromRGB(255,255,255)
    self.Key      = cfg.Key    or Enum.KeyCode.RightAlt
    self._visible = true
    self._tabs    = {}

    self.Gui = Instance.new("ScreenGui")
    self.Gui.Name = "XOUI"
    self.Gui.ResetOnSpawn = false
    self.Gui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
    self.Gui.IgnoreGuiInset = true
    self.Gui.DisplayOrder = 999
    pcall(function() self.Gui.Parent = game:GetService("CoreGui") end)
    if not self.Gui.Parent then
        self.Gui.Parent = LP:WaitForChild("PlayerGui")
    end

    self.Container = Instance.new("Frame")
    self.Container.BackgroundTransparency = 1
    self.Container.Size = UDim2.new(1,0,1,0)
    self.Container.Parent = self.Gui

    -- Watermark with avatar
    self.Watermark = self:createWatermark()

    -- Notifications
    self.NotifAnchor = Instance.new("Frame")
    self.NotifAnchor.BackgroundTransparency = 1
    self.NotifAnchor.AnchorPoint = Vector2.new(1,1)
    self.NotifAnchor.Position = UDim2.new(1,-12,1,-12)
    self.NotifAnchor.Size = UDim2.new(0,260,0,0)
    self.NotifAnchor.AutomaticSize = Enum.AutomaticSize.Y
    self.NotifAnchor.Parent = self.Gui
    local nl = Instance.new("UIListLayout", self.NotifAnchor)
    nl.FillDirection = Enum.FillDirection.Vertical
    nl.VerticalAlignment = Enum.VerticalAlignment.Bottom
    nl.Padding = UDim.new(0,5)

    -- Keybind
    local toggleConn
    local function updateKeybind()
        if toggleConn then toggleConn:Disconnect() end
        toggleConn = UIS.InputBegan:Connect(function(inp,gp)
            if gp then return end
            if inp.KeyCode == self.Key then
                self._visible = not self._visible
                for _, tab in ipairs(self._tabs) do
                    tab.Frame.Visible = self._visible
                end
                self.Watermark.Visible = self._visible
                self.NotifAnchor.Visible = self._visible
            end
        end)
    end
    updateKeybind()

    function self:SetKey(newKey)
        self.Key = newKey
        updateKeybind()
    end

    function self:SetAccent(newColor)
        self.Accent = newColor
        if self.Watermark and self.Watermark.TextLabel then
            self.Watermark.TextLabel.TextColor3 = newColor
        end
    end

    return self
end

function UI:createWatermark()
    local container = Instance.new("Frame")
    container.BackgroundColor3 = T.Panel
    container.BackgroundTransparency = 0
    container.Size = UDim2.new(0, 260, 0, 36)
    container.Position = UDim2.new(0, 12, 0, 12)
    container.Parent = self.Gui
    mkCorner(container, UDim.new(0, 6))
    mkStroke(container, T.Border, 1)

    -- Avatar
    local avatar = Instance.new("ImageLabel")
    avatar.BackgroundTransparency = 1
    avatar.Size = UDim2.new(0, 28, 0, 28)
    avatar.Position = UDim2.new(0, 8, 0.5, -14)
    avatar.Parent = container
    avatar.Image = "https://www.roblox.com/headshot-thumbnail/image?userId=" .. LP.UserId .. "&width=48&height=48&format=png"
    mkCorner(avatar, UDim.new(1,0))

    -- Text
    local textLabel = mkLabel(container, "Molchun Hub | " .. LP.Name,
        UDim2.new(0, 44, 0, 0), UDim2.new(1, -8, 1, 0),
        self.Accent, 12, FONT)
    textLabel.TextXAlignment = Enum.TextXAlignment.Left

    container.TextLabel = textLabel
    return container
end

function UI:AddTab(name)
    local tabIndex = #self._tabs + 1
    local posX = 40 + (tabIndex - 1) * (PANEL_W + GAP)
    local posY = 80

    local tab = setmetatable({}, {__index = self})
    tab._accent   = self.Accent
    tab._window   = self
    tab._name     = name
    tab._sections = {}
    tab._secOrder = 10
    tab._totalHeight = HDR_H

    -- Main frame
    local frame = mkFrame(self.Container, T.Panel,
        UDim2.new(0, posX, 0, posY), UDim2.new(0, PANEL_W, 0, HDR_H), false)
    frame.ZIndex = 10
    mkCorner(frame, UDim.new(0,8))
    mkStroke(frame, T.Border, 1)
    addDropShadow(frame)

    -- Header
    local header = mkBtn(frame,
        UDim2.new(0,0,0,0), UDim2.new(1,0,0,HDR_H), T.PanelHdr)
    mkCorner(header, UDim.new(0,6))
    mkStroke(header, T.Border, 1)
    mkLabel(header, name,
        UDim2.new(0,PAD,0,0), UDim2.new(1,-PAD,1,0),
        T.Text, 13, FONT)
    local divider = mkFrame(frame, T.Border,
        UDim2.new(0,0,0,HDR_H), UDim2.new(1,0,0,1))

    -- Sections container
    local sectionsContainer = Instance.new("Frame")
    sectionsContainer.BackgroundTransparency = 1
    sectionsContainer.Size = UDim2.new(1,0,1,-HDR_H-1)
    sectionsContainer.Position = UDim2.new(0,0,0,HDR_H+1)
    sectionsContainer.Parent = frame
    local secList = Instance.new("UIListLayout", sectionsContainer)
    secList.FillDirection = Enum.FillDirection.Vertical
    secList.SortOrder = Enum.SortOrder.LayoutOrder
    secList.Padding = UDim.new(0, 3)

    makeDraggable(frame, header)

    -- Function to update tab height
    local function updateTabHeight()
        local total = HDR_H + 1   -- header + divider
        for _, sec in ipairs(tab._sections) do
            total = total + sec._currentHeight
        end
        if total ~= tab._totalHeight then
            tab._totalHeight = total
            frame.Size = UDim2.new(0, PANEL_W, 0, total)
        end
    end
    tab._updateHeight = updateTabHeight

    -- Section builder
    function tab:AddSection(secName)
        local section = setmetatable({}, {__index = tab})
        section._accent   = self._accent
        section._itemCnt  = 0
        section._contentH = 0
        section._open     = true
        section._currentHeight = HDR_H

        local secPanel = mkFrame(sectionsContainer, T.Panel,
            UDim2.new(0,0,0,0), UDim2.new(1,0,0,HDR_H), true)
        secPanel.LayoutOrder = tab._secOrder
        tab._secOrder = tab._secOrder + 1
        mkCorner(secPanel, UDim.new(0,5))
        mkStroke(secPanel, T.Border)

        local sHdr = mkBtn(secPanel,
            UDim2.new(0,0,0,0), UDim2.new(1,0,0,HDR_H), T.PanelHdr)
        mkCorner(sHdr, UDim.new(0,5))
        mkLabel(sHdr, secName,
            UDim2.new(0,PAD,0,0), UDim2.new(1,-40,1,0),
            T.Text, 12, FONT)

        local chev = mkLabel(sHdr,"⌄",
            UDim2.new(1,-PAD-12,0,0), UDim2.new(0,12,1,0),
            T.Dim, 14, FONT, Enum.TextXAlignment.Right)

        local divider = mkFrame(secPanel, T.Border,
            UDim2.new(0,0,0,HDR_H), UDim2.new(1,0,0,1))

        local content = mkFrame(secPanel, T.Panel,
            UDim2.new(0,0,0,HDR_H+1), UDim2.new(1,0,0,0))
        local cList = Instance.new("UIListLayout", content)
        cList.FillDirection = Enum.FillDirection.Vertical
        cList.SortOrder = Enum.SortOrder.LayoutOrder
        cList.Padding = UDim.new(0,0)

        local FULL_HDR = HDR_H + 1

        local function syncSize()
            content.Size = UDim2.new(1,0,0,section._contentH)
            local totalH = FULL_HDR + (section._open and section._contentH or 0)
            secPanel.Size = UDim2.new(1,0,0,totalH)
            section._currentHeight = totalH
            if tab._updateHeight then tab._updateHeight() end
        end

        local function grow(h)
            section._contentH = section._contentH + h
            syncSize()
        end
        section._grow = grow

        sHdr.MouseButton1Click:Connect(function()
            section._open = not section._open
            if section._open then
                secPanel.Size = UDim2.new(1,0,0,FULL_HDR+section._contentH)
                chev.Rotation = 0
            else
                secPanel.Size = UDim2.new(1,0,0,HDR_H)
                chev.Rotation = -90
            end
            task.wait(0.05)
            if tab._updateHeight then tab._updateHeight() end
        end)

        hover(sHdr, T.ItemHov, T.PanelHdr)

        -- Row factory
        local function mkRow(h, bg)
            local row = mkBtn(content,
                UDim2.new(0,0,0,0), UDim2.new(1,0,0,h or ITEM_H), bg or T.Item)
            row.LayoutOrder = section._itemCnt
            section._itemCnt = section._itemCnt + 1
            hover(row, T.ItemHov, bg or T.Item)
            grow(h or ITEM_H)
            return row
        end

        -- AddToggle, AddSlider, etc. (unchanged, but we'll keep them)
        function section:AddToggle(name, default, cb, keybind)
            local row = mkRow(ITEM_H)

            local astrip = mkFrame(row, self._accent,
                UDim2.new(0,0,0,4), UDim2.new(0,2,1,-8))
            astrip.BackgroundTransparency = 1
            astrip.ZIndex = 3

            mkLabel(row, name,
                UDim2.new(0,PAD+4,0,0), UDim2.new(1,-92,1,0),
                T.Text, 12, FONTR).ZIndex = 2

            if keybind then
                mkLabel(row, string.lower(tostring(keybind)),
                    UDim2.new(1,-58,0,0), UDim2.new(0,18,1,0),
                    T.Dim, 10, FONTR, Enum.TextXAlignment.Center).ZIndex = 2
            end

            local PW, PH = 34, 18
            local pillX = keybind and (PANEL_W-82) or (PANEL_W-PAD-PW-16)
            local pill = mkFrame(row, T.TogOff,
                UDim2.new(0,pillX,0.5,-PH/2), UDim2.new(0,PW,0,PH))
            pill.ZIndex = 3
            mkCorner(pill, UDim.new(1,0))
            mkStroke(pill, T.Border)

            local dot = mkFrame(pill, T.Dim,
                UDim2.new(0,3,0.5,-7), UDim2.new(0,14,0,14))
            dot.ZIndex = 4
            mkCorner(dot, UDim.new(1,0))

            local state = false

            local function set(v, silent)
                state = v
                local accentDim = self._accent:Lerp(Color3.fromRGB(15,15,22),0.5)
                if state then
                    pill.BackgroundColor3 = accentDim
                    dot.BackgroundColor3 = self._accent
                    dot.Position = UDim2.new(0,PW-3-14,0.5,-7)
                    astrip.BackgroundTransparency = 0
                else
                    pill.BackgroundColor3 = T.TogOff
                    dot.BackgroundColor3 = T.Dim
                    dot.Position = UDim2.new(0,3,0.5,-7)
                    astrip.BackgroundTransparency = 1
                end
                if not silent and cb then pcall(cb,state) end
            end

            set(default or false, true)

            row.MouseButton1Click:Connect(function()
                set(not state)
            end)

            return {Set=set, Get=function() return state end}
        end

        function section:AddSlider(name, min, max, default, cb)
            local H = ITEM_H + 18
            local row = mkRow(H)

            mkLabel(row, name,
                UDim2.new(0,PAD+4,0,3), UDim2.new(1,-58,0,ITEM_H-6),
                T.Dim, 11, FONTR).ZIndex = 2

            local vl = mkLabel(row, tostring(default),
                UDim2.new(1,-PAD-28,0,3), UDim2.new(0,26,0,ITEM_H-6),
                T.Text, 11, FONT, Enum.TextXAlignment.Right)
            vl.ZIndex = 2

            local trkW = PANEL_W - PAD*2 - 4
            local trk  = mkFrame(row, T.SliderBg,
                UDim2.new(0,PAD+2,0,ITEM_H+5), UDim2.new(0,trkW,0,5))
            trk.ZIndex = 3
            mkCorner(trk, UDim.new(1,0))

            local fill = mkFrame(trk, self._accent,
                UDim2.new(0,0,0,0), UDim2.new(0,0,1,0))
            fill.ZIndex = 4
            mkCorner(fill, UDim.new(1,0))

            local thumb = mkFrame(trk, T.White,
                UDim2.new(0,-5,0.5,-5), UDim2.new(0,10,0,10))
            thumb.ZIndex = 5
            mkCorner(thumb, UDim.new(1,0))
            mkStroke(thumb, T.Border)

            local val = math.clamp(default or min, min, max)

            local function setVal(v, silent)
                val = math.clamp(v, min, max)
                local pct = (val-min)/(max-min)
                local fw  = math.max(pct*trkW, 5)
                fill.Size = UDim2.new(0,fw,1,0)
                thumb.Position = UDim2.new(0,fw-5,0.5,-5)
                vl.Text = tostring(math.floor(val*10+0.5)/10)
                if not silent and cb then pcall(cb,val) end
            end

            setVal(val, true)

            local drag = false
            local hb = mkBtn(trk, UDim2.new(0,0,-1.5,0),
                UDim2.new(1,0,4,0), T.Black)
            hb.BackgroundTransparency = 1
            hb.ZIndex = 6

            hb.InputBegan:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = true end
            end)
            UIS.InputEnded:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseButton1 then drag = false end
            end)
            UIS.InputChanged:Connect(function(inp)
                if drag and inp.UserInputType == Enum.UserInputType.MouseMovement then
                    local pct = math.clamp(
                        (inp.Position.X - trk.AbsolutePosition.X) / trk.AbsoluteSize.X, 0, 1)
                    setVal(min + (max-min)*pct)
                end
            end)

            return {Set=setVal, Get=function() return val end}
        end

        function section:AddButton(name, cb, keybind)
            local row = mkRow(ITEM_H)

            mkLabel(row, name,
                UDim2.new(0,PAD+4,0,0), UDim2.new(1,-PAD*2-20,1,0),
                T.Text, 12, FONTR).ZIndex = 2

            if keybind then
                local kb = typeof(keybind)=="string" and keybind or keybind.Name:lower()
                mkLabel(row, kb,
                    UDim2.new(1,-PAD-32,0,0), UDim2.new(0,28,1,0),
                    T.Dim, 10, FONTR, Enum.TextXAlignment.Right).ZIndex = 2
            end

            row.MouseButton1Click:Connect(function()
                if cb then pcall(cb) end
            end)

            return row
        end

        function section:AddKeybind(name, default, cb)
            local row     = mkRow(ITEM_H)
            local binding = default or Enum.KeyCode.Unknown
            local waiting = false

            mkLabel(row, name,
                UDim2.new(0,PAD+4,0,0), UDim2.new(1,-90,1,0),
                T.Text, 12, FONTR).ZIndex = 2

            local function kname(kc)
                if kc == Enum.KeyCode.Unknown then return "none" end
                return kc.Name:lower()
            end

            local badge = mkFrame(row, T.SliderBg,
                UDim2.new(1,-PAD-42,0.5,-9), UDim2.new(0,38,0,18))
            badge.ZIndex = 3
            mkCorner(badge, UDim.new(0,3))
            mkStroke(badge, T.Border)

            local kl = mkLabel(badge, kname(binding),
                UDim2.new(0,0,0,0), UDim2.new(1,0,1,0),
                T.Dim, 10, FONT, Enum.TextXAlignment.Center)
            kl.ZIndex = 4

            row.MouseButton1Click:Connect(function()
                waiting = true
                kl.Text = "..."
                kl.TextColor3 = self._accent
                badge.BackgroundColor3 = T.ItemAct
            end)

            UIS.InputBegan:Connect(function(inp,gp)
                if gp or not waiting then return end
                if inp.UserInputType == Enum.UserInputType.Keyboard then
                    binding = inp.KeyCode
                    waiting = false
                    kl.Text = kname(binding)
                    kl.TextColor3 = T.Dim
                    badge.BackgroundColor3 = T.SliderBg
                    if cb then pcall(cb, binding) end
                end
            end)

            return {
                Get = function() return binding end,
                Set = function(kc) binding=kc; kl.Text=kname(kc) end,
            }
        end

        function section:AddDropdown(name, options, default, cb)
            local row = mkRow(ITEM_H)
            local sel = default or options[1] or ""
            local open, dropFrame = false, nil

            mkLabel(row, name,
                UDim2.new(0,PAD+4,0,0), UDim2.new(1,-110,1,0),
                T.Text, 12, FONTR).ZIndex = 2

            local vBadge = mkFrame(row, T.SliderBg,
                UDim2.new(1,-PAD-72,0.5,-9), UDim2.new(0,68,0,18))
            vBadge.ZIndex = 3
            mkCorner(vBadge, UDim.new(0,3))
            mkStroke(vBadge, T.Border)

            local vl = mkLabel(vBadge, sel,
                UDim2.new(0,5,0,0), UDim2.new(1,-8,1,0),
                self._accent, 10, FONT)
            vl.ZIndex = 4

            local function close()
                open = false
                if dropFrame then
                    dropFrame:Destroy()
                    dropFrame = nil
                end
            end

            row.MouseButton1Click:Connect(function()
                if open then close(); return end
                open = true
                dropFrame = mkFrame(content, T.ItemAct,
                    UDim2.new(0,0,0,0), UDim2.new(1,0,0,0), true)
                dropFrame.LayoutOrder = row.LayoutOrder + 0.5
                dropFrame.ZIndex = 20

                local target = #options * ITEM_H
                dropFrame.Size = UDim2.new(1,0,0,target)

                for i, opt in ipairs(options) do
                    local ob = mkBtn(dropFrame,
                        UDim2.new(0,0,0,(i-1)*ITEM_H),
                        UDim2.new(1,0,0,ITEM_H), T.Item)
                    ob.ZIndex = 21
                    hover(ob)

                    if opt == sel then
                        mkFrame(ob, self._accent,
                            UDim2.new(0,0,0,0), UDim2.new(0,2,1,0)).ZIndex = 22
                    end

                    mkLabel(ob, opt,
                        UDim2.new(0,PAD+4,0,0), UDim2.new(1,-PAD*2,1,0),
                        opt==sel and self._accent or T.Text,
                        11, opt==sel and FONT or FONTR).ZIndex = 22

                    ob.MouseButton1Click:Connect(function()
                        sel = opt; vl.Text = sel
                        close()
                        if cb then pcall(cb, sel) end
                    end)
                end
            end)

            return {
                Set=function(v) sel=v; vl.Text=v; if cb then pcall(cb,v) end end,
                Get=function() return sel end,
            }
        end

        function section:AddLabel(text, color)
            local row = mkRow(ITEM_H, T.Panel)
            row.BackgroundColor3 = T.Panel
            mkLabel(row, text,
                UDim2.new(0,PAD+4,0,0), UDim2.new(1,-PAD*2,1,0),
                color or T.Dim, 11, FONTR).ZIndex = 2
            return row
        end

        function section:AddSeparator(text)
            local h = text and 22 or 1
            local row = mkRow(h, T.Panel)
            row.BackgroundColor3 = T.Panel
            if text then
                mkLabel(row, text,
                    UDim2.new(0,PAD+4,0,0), UDim2.new(1,-PAD*2,1,0),
                    T.Muted, 10, FONT).ZIndex = 2
            end
        end

        function section:AddColorPicker(name, default, cb)
            local row = mkRow(ITEM_H)
            local col = default or T.White
            local pickerOpen, pickerFrame = false, nil

            mkLabel(row, name,
                UDim2.new(0,PAD+4,0,0), UDim2.new(1,-70,1,0),
                T.Text, 12, FONTR).ZIndex = 2

            local sw = mkFrame(row, col,
                UDim2.new(1,-PAD-36,0.5,-8), UDim2.new(0,32,0,16))
            sw.ZIndex = 3
            mkCorner(sw, UDim.new(0,3))
            mkStroke(sw, T.Border)

            local function createPickerUI()
                local picker = mkFrame(content, T.PanelHdr,
                    UDim2.new(0,0,0,0), UDim2.new(1,0,0,0), true)
                picker.LayoutOrder = row.LayoutOrder + 0.5
                picker.ZIndex = 20
                picker.Size = UDim2.new(1,0,0,164)

                -- Simplified color picker (just show a placeholder for now)
                mkLabel(picker, "Color picker placeholder", UDim2.new(0,0,0,0), UDim2.new(1,0,1,0), T.Text, 12)
                return picker
            end

            row.MouseButton1Click:Connect(function()
                if pickerOpen then
                    if pickerFrame then pickerFrame:Destroy() end
                    pickerOpen = false
                else
                    pickerOpen = true
                    pickerFrame = createPickerUI()
                end
            end)

            return {
                Get = function() return col end,
                Set = function(c) col=c; sw.BackgroundColor3=c; if cb then pcall(cb,c) end end,
            }
        end

        table.insert(tab._sections, section)
        tab._updateHeight()
        return section
    end

    -- Default section for direct methods
    do
        local _defaultSection = nil
        local function getDefaultSection()
            if not _defaultSection then
                _defaultSection = tab:AddSection(name)
            end
            return _defaultSection
        end
        function tab:AddToggle(...)     return getDefaultSection():AddToggle(...)     end
        function tab:AddSlider(...)     return getDefaultSection():AddSlider(...)     end
        function tab:AddButton(...)     return getDefaultSection():AddButton(...)     end
        function tab:AddKeybind(...)    return getDefaultSection():AddKeybind(...)    end
        function tab:AddDropdown(...)   return getDefaultSection():AddDropdown(...)   end
        function tab:AddLabel(...)      return getDefaultSection():AddLabel(...)      end
        function tab:AddSeparator(...)  return getDefaultSection():AddSeparator(...)  end
        function tab:AddColorPicker(...)return getDefaultSection():AddColorPicker(...)end
        function tab:Notify(...)        return self._window:Notify(...)               end
    end

    table.insert(self._tabs, tab)
    return tab
end

function UI:Notify(text, duration, title)
    duration = duration or 3
    local nf = mkFrame(self.NotifAnchor, T.Panel,
        UDim2.new(0,0,0,0), UDim2.new(1,0,0,title and 50 or 40))
    mkCorner(nf, UDim.new(0,5))
    mkStroke(nf, T.Border)

    local ab = mkFrame(nf, self.Accent,
        UDim2.new(0,0,0,6), UDim2.new(0,3,1,-12))
    mkCorner(ab, UDim.new(1,0))

    if title then
        mkLabel(nf, title,
            UDim2.new(0,12,0,5), UDim2.new(1,-16,0,14),
            self.Accent, 10, FONT).ZIndex = 2
        mkLabel(nf, text,
            UDim2.new(0,12,0,20), UDim2.new(1,-16,0,26),
            T.Dim, 11, FONTR).ZIndex = 2
    else
        mkLabel(nf, text,
            UDim2.new(0,12,0,0), UDim2.new(1,-16,1,0),
            T.Text, 12, FONTR).ZIndex = 2
    end

    nf.Position = UDim2.new(1,20,0,0)
    nf.Position = UDim2.new(0,0,0,0) -- instantly show

    task.delay(duration, function()
        nf:Destroy()
    end)
end

function UI:Destroy()
    if self.Gui then self.Gui:Destroy() end
end

return UI
